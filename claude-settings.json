{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(gcc:*)",
      "Bash(g++:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(cd:*)",
      "Bash(touch:*)",
      "Bash(tar:*)",
      "Bash(sudo:*)",
      "Bash(apt-get:*)",
      "Bash(apt:*)",
      "Bash(vi:*)",
      "Bash(vim:*)",
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Task",
      "WebFetch",
      "WebSearch",
      "mcp__chrome-devtools*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "changes=$(git status --porcelain 2>/dev/null); if [ -n \"$changes\" ]; then file_count=$(echo \"$changes\" | wc -l | tr -d ' '); echo \"{\\\"systemMessage\\\":\\\"检测到 ${file_count} 个文件有变更，是否需要提交到 GitHub？请回复 /commit 快速提交，或告诉我你想如何处理这些变更。\\\"}\"; fi",
            "timeout": 10,
            "statusMessage": "检查 Git 变更..."
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "hasCompletedOnboarding": true,
  "skipDangerousModePermissionPrompt": true
}
