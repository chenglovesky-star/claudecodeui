# Claude Code UI Docker 部署配置

# Anthropic API Key — 二选一：
# 方式1: 填入 API Key（团队共用）
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# 方式2: 在 docker-compose.yml 中挂载宿主机 ~/.claude 目录（使用本地已登录的账号）

# 服务端口 (容器内部)
PORT=3001

# 绑定地址
HOST=0.0.0.0

# 数据库路径 (容器内路径，通过 volume 持久化)
DATABASE_PATH=/data/db/auth.db

# 工作空间根目录 (容器内路径，通过 volume 持久化)
WORKSPACES_ROOT=/workspace

# Claude 上下文窗口大小
CONTEXT_WINDOW=160000

# 是否允许新用户注册 (首次部署后可关闭)
ALLOW_REGISTRATION=true

# 沙箱配置
SANDBOX_ENABLED=true
